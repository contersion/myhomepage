# =============================================================================
# My Homepage - Environment Configuration
# =============================================================================
# ⚠️  WARNING: This is an example file. Copy to .env and MODIFY ALL VALUES.
# ⚠️  DO NOT use default values in production - security risk!
# =============================================================================

# -----------------------------------------------------------------------------
# Database (SQLite)
# -----------------------------------------------------------------------------
# 本地开发使用相对路径即可（以项目根为基准）
# Docker 部署时必须使用绝对路径：file:/app/storage/data/app.db
# 已在 docker-compose.yml 中自动配置，请勿在 compose 中继续使用相对路径
DATABASE_URL="file:./storage/data/app.db"

# -----------------------------------------------------------------------------
# Session Secrets - CRITICAL: MUST CHANGE BEFORE PRODUCTION
# -----------------------------------------------------------------------------
# Generate strong random strings (at least 32 characters):
#   Linux/Mac: openssl rand -base64 48
#   Windows:   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# 
# ⚠️  Requirements:
#   - Minimum 32 characters
#   - Two secrets MUST be different
#   - Keep these secret - treat like passwords
#   - Changing secrets will invalidate all existing sessions
#
VISITOR_SESSION_SECRET="REPLACE_WITH_YOUR_OWN_SECRET_MIN_32_CHARS_LONG"
ADMIN_SESSION_SECRET="REPLACE_WITH_A_DIFFERENT_SECRET_MIN_32_CHARS_LONG"

# -----------------------------------------------------------------------------
# Initial Passwords - CRITICAL: MUST CHANGE AFTER FIRST LOGIN
# -----------------------------------------------------------------------------
# Default passwords for first-time setup.
# ⚠️  Change immediately after first login via /admin
#
VISITOR_PASSWORD="visitor123"
ADMIN_PASSWORD="admin123"

# -----------------------------------------------------------------------------
# Upload Configuration
# -----------------------------------------------------------------------------
UPLOAD_DIR="./storage/uploads"
MAX_UPLOAD_SIZE="5242880"  # 5MB default, max 10MB recommended

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
NODE_ENV="production"  # Use "development" for local dev only
PORT="3456"

# =============================================================================
# CHECKLIST BEFORE PRODUCTION DEPLOYMENT:
# =============================================================================
# [ ] Copied this file to .env (cp .env.example .env)
# [ ] Changed VISITOR_SESSION_SECRET to random string (>= 32 chars)
# [ ] Changed ADMIN_SESSION_SECRET to random string (>= 32 chars, different)
# [ ] Two secrets are NOT the same
# [ ] Considered changing default passwords (can also change after first login)
# [ ] Set NODE_ENV to "production"
# [ ] Verified storage directories exist and have correct permissions
# [ ] Ran `npm run preflight` and all checks passed
# =============================================================================
